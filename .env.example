# CB_Marketing Environment Variables
# Copy this file to .env and fill in your real values
# NEVER commit .env to version control

# === API Keys ===
ANTHROPIC_AUTH_TOKEN=
APIFY_API_KEY=
NOTION_API_KEY=
SLACK_BOT_TOKEN=
HIGGSFIELD_API_KEY=

# === Meta Ads (Graph API) ===
# Generate a long-lived token (60-day) via developers.facebook.com/tools/explorer/
# Permissions needed: ads_read, ads_management, business_management
# Token expires every 60 days — renew at developers.facebook.com/tools/debug/accesstoken/
META_ACCESS_TOKEN=
META_GRAPH_VERSION=v21.0
META_WEEKS=4

# === Google Analytics 4 ===
# Found in GA4 → Admin → Property Settings → Property ID (numeric, e.g. 123456789)
# ⚠️ This is GA4_PROPERTY_ID — NOT GA4_MEASUREMENT_ID (different thing)
GA4_PROPERTY_ID=

# === Google Search Console ===
# Handled via OAuth credentials in secrets/ — no separate env var needed

# === Google Ads API ===
# Developer token: Google Ads account → Tools → API Centre
GOOGLE_ADS_DEVELOPER_TOKEN=
# Manager (MCC) account ID — format: 123-456-7890
GOOGLE_ADS_MANAGER_ID=
# Individual location account IDs (without dashes)
GOOGLE_ADS_CUSTOMER_ID_MALAGA=
GOOGLE_ADS_CUSTOMER_ID_ELLENBROOK=

# === Google Business Profile ===
# Handled via OAuth credentials in secrets/ — no separate env var needed

# === Model Configuration ===
# Standard tasks (fast, via OpenRouter)
CLAUDE_MODEL_STANDARD=minimax/minimax-m2.7
# Heavy tasks (local Ollama — requires Ollama running at localhost:11434)
CLAUDE_MODEL_HEAVY=gemma4:31b-cloud
OLLAMA_BASE_URL=http://localhost:11434

# === Email (for weekly SEO reports) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tia@chasingbetter.com.au
SMTP_PASS=your-app-password-here
