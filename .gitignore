# Security — never commit these
.env
.env.local
.env.*
*.env
# Exception: .env.example is safe to commit (template only, no real values)
!.env.example

# API Keys & Secrets
secrets/
.secrets
api-keys.txt

# Claude Code local settings — contains API keys and auth tokens
.claude/settings.json
.claude/settings.local.json

# Sensitive outputs
outputs/reports/financial-*
state/*.json

# Python cache
__pycache__/
*.pyc
*.pyo

# Backup files
*.bak

# Error logs
state/data-refresh.err

# Auto-generated context snapshots (rebuilt each session)
context/*-context.json

# LaunchAgent plist (machine-specific)
scripts/com.cb247.data-refresh.plist

# System files
.DS_Store
node_modules/
*.log
